<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="12.0"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="hu.ppke.itk.beadando.client.controller.ChatController"
      style="-fx-background-color: #ffffff;">
    <padding>
        <Insets bottom="16.0" left="16.0" right="16.0" top="16.0"/>
    </padding>

    <!-- Chat lista -->
    <ListView fx:id="chatList" VBox.vgrow="ALWAYS"
              style="-fx-background-color: transparent;
                     -fx-border-color: #e5e7eb;
                     -fx-border-radius: 12;
                     -fx-background-radius: 12;"/>

    <!-- Input sor -->
    <HBox spacing="8.0" alignment="CENTER">
        <TextField fx:id="inputField"
                   promptText="Írj üzenetet..."
                   onAction="#onSend"
                   HBox.hgrow="ALWAYS"
                   style="-fx-background-radius: 20;
                          -fx-border-radius: 20;
                          -fx-border-color: #e5e7eb;
                          -fx-padding: 8 14 8 14;
                          -fx-font-size: 14px;"/>
        <Button fx:id="send"
                text="Küldés"
                onAction="#onSend"
                style="-fx-background-color: #3b82f6;
                       -fx-text-fill: white;
                       -fx-background-radius: 20;
                       -fx-padding: 8 18 8 18;
                       -fx-font-size: 14px;
                       -fx-cursor: hand;"/>
    </HBox>
</VBox>