<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="16.0"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="hu.ppke.itk.beadando.RegisterView"
      prefHeight="250.0" prefWidth="400.0">
    <padding>
        <Insets bottom="20.0" left="40.0" right="40.0" top="20.0"/>
    </padding>

    <Label text="Felhasználónév"/>
    <TextField fx:id="user_name" promptText="Felhasználónév"/>

    <Label text="Jelszó"/>
    <PasswordField fx:id="password" promptText="Jelszó"/>

    <Label fx:id="errorLabel" style="-fx-text-fill: red;" text=""/>

    <Button text="Regisztráció" onAction="#regist" maxWidth="Infinity"/>
</VBox>